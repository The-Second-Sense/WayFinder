{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "buildpacks": []
  },
  "deploy": {
    "startCommand": "",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "healthchecks": {
      "enabled": true,
      "interval": 10000,
      "timeout": 5000,
      "startPeriod": 60000
    },
    "numReplicas": 1,
    "autoDeploy": true
  },
  "plugins": [],
  "env": {
    "PORT": "8080",
    "JAVA_OPTS": "-Xmx512m -Xms256m"
  }
}

